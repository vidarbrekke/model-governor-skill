{
  "name": "router-governor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "cases": "node --loader ts-node/esm tests/run-cases.ts",
    "bridge": "node dist/src/cli.js",
    "log:report": "node dist/src/log-report.js --hours 24",
    "activate": "bash scripts/post-pull-activate.sh",
    "proxy": "node dist/src/gateway-proxy.js"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "ts-node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
